# DevAnalysis114 환경변수 예시
# 이 파일을 .env로 복사 후 실제 값을 설정하세요

# Application
APP_DEBUG=false
APP_ENV=dev

# Domain
DOMAIN_NAME=xn--114-2p7l635dz3bh5j.com
DOMAIN_ORIGINAL=개발분석114.com

# Database
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=devanalysis114
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# JWT
JWT_SECRET_KEY=change-this-to-a-strong-random-secret
SECRET_KEY=change-this-to-a-strong-random-secret

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=marketplace-projects

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3005,http://127.0.0.1:3000,http://127.0.0.1:3005

# LLM
LLM_MODEL_DEFAULT=qwen2.5-coder:32b
OLLAMA_BASE=http://host.docker.internal:8008/v1

# Video
VIDEO_REQUIRE_GENERATIVE_ENGINE=false
VIDEO_ENGINE_FALLBACK_TO_INTERNAL=true

# Workers
ENABLE_AD_ORDER_WORKER_BOOTSTRAP=true
ENABLE_SELF_RUN_VIDEO_WORKER_BOOTSTRAP=false

# Marketplace
MARKETPLACE_BILLING_ALLOW_SIMULATED_CHECKOUT=true

# SSL
SSL_EMAIL=admin@example.com

# Nginx
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
