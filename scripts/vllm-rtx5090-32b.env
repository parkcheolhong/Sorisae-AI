# RTX 5090 32GB — vLLM 32B AWQ (코딩·오케스트레이터·Autonomous A뇌)
# gpu-llm-server docker-compose .env 또는 vLLM 기동 스크립트에 복사

VLLM_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct-AWQ
VLLM_QUANTIZATION=awq
VLLM_DTYPE=auto
VLLM_MAX_MODEL_LEN=8192
VLLM_GPU_MEMORY_UTILIZATION=0.92
VLLM_PORT=8008
VLLM_HOST=0.0.0.0

# codeAI backend (docker-compose / native)
OLLAMA_BASE=http://host.docker.internal:8008/v1
LLM_MODEL_DEFAULT=Qwen/Qwen2.5-Coder-32B-Instruct-AWQ
LLM_MODEL_REASONING=Qwen/Qwen2.5-Coder-32B-Instruct-AWQ
LLM_MODEL_CODING=Qwen/Qwen2.5-Coder-32B-Instruct-AWQ
LLM_MODEL_PLANNER=Qwen/Qwen2.5-Coder-32B-Instruct-AWQ
LLM_MODEL_CODER=Qwen/Qwen2.5-Coder-32B-Instruct-AWQ
LLM_MODEL_REVIEWER=Qwen/Qwen2.5-Coder-32B-Instruct-AWQ
LLM_RESOLVE_LIVE_MODELS=true
ORCHESTRATOR_CHAT_TIMEOUT_SEC=180

# 14B만 로드된 경우 자동 폴백 (개발·VRAM 부족 시)
# FALLBACK_VLLM_MODEL_14B_AWQ=Qwen/Qwen2.5-Coder-14B-Instruct-AWQ
