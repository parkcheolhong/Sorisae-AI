{
    "name": "devanalysis114-frontend",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "test": "node -e \"const assert=require(\\\"node:assert/strict\\\"); assert.equal(2,2); console.log(\\\"frontend smoke tests passed\\\");\" && node tests/rail-labels.test.mjs && node tests/nadotongryoksa-contracts.test.mjs",
        "start": "next start",
        "e2e": "playwright test -c playwright.config.ts",
        "e2e:headed": "playwright test -c playwright.config.ts --headed",
        "e2e:marketplace-liveview": "playwright test -c playwright.config.ts tests/marketplace-liveview-ai-image.playwright.spec.ts --project chromium --no-deps",
        "e2e:marketplace-liveview:sheet": "playwright test -c playwright.config.ts tests/marketplace-liveview-ai-sheet-launcher.playwright.spec.ts --project chromium --no-deps",
        "e2e:marketplace-liveview:launcher": "playwright test -c playwright.config.ts tests/marketplace-liveview-ai-image-launcher.playwright.spec.ts --project chromium --no-deps",
        "e2e:marketplace-liveview:all": "playwright test -c playwright.config.ts tests/marketplace-liveview-ai-image.playwright.spec.ts tests/marketplace-liveview-ai-image-launcher.playwright.spec.ts --project chromium --no-deps",
        "e2e:marketplace:music-token": "playwright test -c playwright.config.ts tests/marketplace-music-panel-auth-e2e.playwright.spec.ts --project chromium --no-deps",
        "e2e:marketplace:shinsegye-safe": "playwright test -c playwright.config.ts tests/marketplace-shinsegye-safe-integration.playwright.spec.ts --project chromium --no-deps",
        "ci:marketplace:shinsegye-safe:2round": "npm run e2e:marketplace:shinsegye-safe && npm run e2e:marketplace:shinsegye-safe",
        "ci:admin-regression:smoke": "playwright test -c playwright.config.ts tests/admin-login.playwright.spec.ts tests/admin-dashboard-ops.playwright.spec.ts tests/admin-dashboard-capability-notice.playwright.spec.ts --project chromium",
        "ci:admin-regression:full": "playwright test -c playwright.config.ts tests/admin-login.playwright.spec.ts tests/admin-dashboard-ops.playwright.spec.ts tests/admin-dashboard-capability-notice.playwright.spec.ts tests/admin-llm-render.playwright.spec.ts tests/admin-passkey-operational.playwright.spec.ts tests/admin-system-settings-operational.playwright.spec.ts tests/admin-storyboard-review.playwright.spec.ts tests/admin-swagger-popup.playwright.spec.ts tests/ui-pod-admin-users.playwright.spec.ts tests/orchestrator-ui-reverse-question-smoke.playwright.spec.ts --project chromium"
    },
    "dependencies": {
        "@types/node": "^20.14.12",
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "axios": "^1.16.0",
        "clsx": "^2.1.1",
        "jszip": "^3.10.1",
        "lucide-react": "^0.408.0",
        "mermaid": "^11.15.0",
        "next": "^16.2.6",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "tailwind-merge": "^2.4.0",
        "typescript": "^6.0.0",
        "zustand": "^4.5.4"
    },
    "devDependencies": {
        "@playwright/test": "^1.54.2",
        "autoprefixer": "^10.4.19",
        "eslint": "^10.1.0",
        "postcss": "^8.5.12",
        "tailwindcss": "^3.4.6"
    },
    "overrides": {
        "postcss": "^8.5.12",
        "uuid": "^14.0.0"
    }
}