{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [
      {
        "source": "/api/:path*",
        "destination": "/api/backend-proxy/:path*",
        "regex": "^/api(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      }
    ],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/admin/users/[userId]",
      "regex": "^/api/admin/users/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPuserId": "nxtPuserId"
      },
      "namedRegex": "^/api/admin/users/(?<nxtPuserId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/backend-proxy/[...path]",
      "regex": "^/api/backend\\-proxy/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPpath": "nxtPpath"
      },
      "namedRegex": "^/api/backend\\-proxy/(?<nxtPpath>.+?)(?:/)?$"
    },
    {
      "page": "/api/marketplace/customer-orchestrate/stage-runs/[runId]",
      "regex": "^/api/marketplace/customer\\-orchestrate/stage\\-runs/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPrunId": "nxtPrunId"
      },
      "namedRegex": "^/api/marketplace/customer\\-orchestrate/stage\\-runs/(?<nxtPrunId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/marketplace/[id]",
      "regex": "^/marketplace/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/marketplace/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/[...adminOnly]",
      "regex": "^/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPadminOnly": "nxtPadminOnly"
      },
      "namedRegex": "^/(?<nxtPadminOnly>.+?)(?:/)?$"
    }
  ],
