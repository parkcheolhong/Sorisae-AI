{
  "extends": "./tsconfig.shared.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "es2019",
      "es2020",
      "esnext"
    ],
    "module": "esnext",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "types": [
      "node",
      "react",
      "react-dom",
      "@playwright/test"
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@shared/*": [
        "./shared/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "shared/**/*.tsx",
    "shared/**/*.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".next-dev-admin-3005/types/**/*.ts",
    ".next-dev-admin-3005/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
